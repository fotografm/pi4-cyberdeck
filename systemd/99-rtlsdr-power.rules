# Disable USB autosuspend for RTL2838 dongle.
# The kernel may suspend idle USB devices; RTL-SDR sticks often fail to wake
# cleanly and re-enumerate as a new device, breaking the open file handle.
ACTION=="add", SUBSYSTEM=="usb", ATTRS{idVendor}=="0bda", ATTRS{idProduct}=="2838", TEST=="power/autosuspend", ATTR{power/control}="on"
