[Unit]
Description=raspi81 WiFi Web Server (port 8091)
After=network.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/ism-wifi-monitor
ExecStartPre=+-/bin/bash -c 'chown user:user /home/user/ism-wifi-monitor/db/wifi_logger.db* 2>/dev/null'
ExecStartPre=/bin/sleep 8
ExecStart=/home/user/ism-wifi-monitor/venv/bin/python /home/user/ism-wifi-monitor/wifi_web.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
